# REQUIRED — SEC EDGAR fair-access identification (your name/org + contact email)
SEC_IDENTITY=""
# Database (default: local sqlite). Postgres: postgresql://user:pw@host:5432/form4lab
DATABASE_URL=sqlite:///form4lab.db
# Active strategy (module:Class), resolved lazily on first use (not at
# startup) — validate STRATEGY_PATH before deploying, since a bad path
# fails on the first request/job that needs it, not at boot.
STRATEGY_PATH=form4lab.strategies.cluster_buy:ClusterBuyStrategy
# Paper trading (optional; requires `pip install form4lab[trade]`)
ALPACA_ENABLED=false
ALPACA_PAPER=true
ALPACA_API_KEY=""
ALPACA_SECRET_KEY=""

# Docker: DATABASE_URL and SCHEDULER_ENABLED are set for you by
# docker-compose.yml; you only need to export SEC_IDENTITY before
# `docker compose up`. Drop custom strategies into ./strategies
# (bind-mounted to /app/strategies in both the web and scheduler
# containers) and point STRATEGY_PATH at them, e.g.
# STRATEGY_PATH=strategies.my_strategy:MyStrategy.
